<mujoco model="rbtheron">
  <compiler angle="radian" autolimits="true"/>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" material="theron_dark"/>
    </default>
    <default class="wheel">
      <joint axis="0 1 0" damping="0.2" armature="0.02"/>
      <geom
        type="cylinder"
        size="0.0762 0.03"
        quat="0.707107 0.707107 0 0"
        condim="4"
        friction="4.5 0.02 0.0001"
        rgba="0.12 0.12 0.12 1"
      />
    </default>
    <default class="support">
      <geom
        type="sphere"
        size="0.035"
        friction="0.001 0.0001 0.00001"
        solimp="0.70 0.90 0.001"
        solref="0.04 1"
        rgba="0 0 0 0"
      />
    </default>
    <default class="support_visual">
      <geom
        type="cylinder"
        size="0.045 0.014"
        quat="0.707107 0.707107 0 0"
        contype="0"
        conaffinity="0"
        rgba="0.10 0.10 0.10 1"
      />
    </default>
  </default>

  <asset>
    <material name="theron_dark" rgba="0.20 0.20 0.20 1"/>
    <mesh name="theron_base_v4" content_type="model/stl" file="assets/theron_base_v4.stl"/>
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0">
      <freejoint/>
      <inertial pos="0 0 0" mass="42" diaginertia="2.0 3.0 3.5"/>
      <geom name="chassis_visual" class="visual" mesh="theron_base_v4" pos="0 0 0.0762"/>
      <geom
        name="chassis_collision"
        type="box"
        pos="0 0 0.145"
        size="0.29 0.22 0.055"
        friction="0.8 0.005 0.0001"
        rgba="0 0 0 0"
      />

      <body name="right_wheel_link" pos="0 -0.2516 0.0762">
        <inertial pos="0 0 0" mass="2.5" diaginertia="0.012 0.006 0.006"/>
        <joint name="right_wheel_joint" axis="0 1 0" damping="0.2" armature="0.02"/>
        <geom name="right_wheel_geom" class="wheel"/>
      </body>

      <body name="left_wheel_link" pos="0 0.2516 0.0762">
        <inertial pos="0 0 0" mass="2.5" diaginertia="0.012 0.006 0.006"/>
        <joint name="left_wheel_joint" axis="0 1 0" damping="0.2" armature="0.02"/>
        <geom name="left_wheel_geom" class="wheel"/>
      </body>

      <body name="front_left_support_link" pos="0.235 0.1825 0.035">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="front_left_support_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom name="front_left_support" class="support"/>
        <geom name="front_left_support_visual" class="support_visual"/>
      </body>
      <body name="front_right_support_link" pos="0.235 -0.1825 0.035">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="front_right_support_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom name="front_right_support" class="support"/>
        <geom name="front_right_support_visual" class="support_visual"/>
      </body>
      <body name="rear_left_support_link" pos="-0.235 0.1825 0.035">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="rear_left_support_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom name="rear_left_support" class="support"/>
        <geom name="rear_left_support_visual" class="support_visual"/>
      </body>
      <body name="rear_right_support_link" pos="-0.235 -0.1825 0.035">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="rear_right_support_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom name="rear_right_support" class="support"/>
        <geom name="rear_right_support_visual" class="support_visual"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="right_wheel_vel" joint="right_wheel_joint" kv="35" ctrlrange="-22 22"/>
    <velocity name="left_wheel_vel" joint="left_wheel_joint" kv="35" ctrlrange="-22 22"/>
  </actuator>
</mujoco>
