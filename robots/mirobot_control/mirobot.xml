<mujoco model="mirobot">
  <compiler angle="radian" meshdir="assets"/>

  <option integrator="implicitfast" cone="elliptic" impratio="10"/>

  <default>
    <default class="mirobot">
      <joint armature="0.01" damping="1.5" frictionloss="0.05"/>
      <position kp="40" kv="6" inheritrange="1" forcerange="-80 80"/>
      <default class="visual">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
      </default>
    </default>
  </default>

  <asset>
    <mesh name="mirobot_base_link" file="base_link.STL"/>
    <mesh name="mirobot_Link1" file="Link1.STL"/>
    <mesh name="mirobot_Link2" file="Link2.STL"/>
    <mesh name="mirobot_Link3" file="Link3.STL"/>
    <mesh name="mirobot_Link4" file="Link4.STL"/>
    <mesh name="mirobot_Link5" file="Link5.STL"/>
    <mesh name="mirobot_Link6" file="Link6.STL"/>
  </asset>

  <worldbody>
    <body name="base_link" childclass="mirobot" gravcomp="1">
      <inertial pos="0.00072554 2.2065E-05 0.024268" mass="0.10" diaginertia="0.001 0.001 0.001"/>
      <geom class="visual" rgba="0.44 0.5 0.56 1" mesh="mirobot_base_link"/>
      <geom class="collision" rgba="0.44 0.5 0.56 1" mesh="mirobot_base_link"/>

      <body name="Link1" pos="0 0 0.065406">
        <inertial pos="0.011601 0.022341 0.044136" mass="0.05" diaginertia="0.001 0.001 0.001"/>
        <joint name="joint1" axis="0 0 1" range="-1.7453 2.7925"/>
        <geom class="visual" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link1"/>
        <geom class="collision" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link1"/>

        <body name="Link2" pos="0.029687 -0.022 0.061593" quat="-0.500004 0.499996 0.500002 0.499998">
          <inertial pos="0.054694 0.0036383 -0.0056108" mass="0.05" diaginertia="0.001 0.001 0.001"/>
          <joint name="joint2" axis="0 0 1" range="-0.5235 1.2217"/>
          <geom class="visual" rgba="1 0.65 0 1" mesh="mirobot_Link2"/>
          <geom class="collision" rgba="1 0.65 0 1" mesh="mirobot_Link2"/>

          <body name="Link3" pos="0.108 0 -0.0094471">
            <inertial pos="0.0099997 0.0071403 0.037517" mass="0.04" diaginertia="0.001 0.001 0.001"/>
            <joint name="joint3" axis="0 0 1" range="-2.9671 1.0472"/>
            <geom class="visual" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link3"/>
            <geom class="collision" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link3"/>

            <body name="Link4" pos="0.020001 0.10743 0.031439" quat="0.707105 -0.707108 0 0">
              <inertial pos="-8.0804e-06 0.0043797 0.040569" mass="0.03" diaginertia="0.001 0.001 0.001"/>
              <joint name="joint4" axis="0 0 1" range="-6.1086 6.1086"/>
              <geom class="visual" rgba="1 0.65 0 1" mesh="mirobot_Link4"/>
              <geom class="collision" rgba="1 0.65 0 1" mesh="mirobot_Link4"/>

              <body name="Link5" pos="0 -0.010414 0.06155" quat="0.5 -0.500002 -0.499998 -0.5">
                <inertial pos="0.00025302 -0.0020133 0.010352" mass="0.02" diaginertia="0.001 0.001 0.001"/>
                <joint name="joint5" axis="0 0 -1" range="-3.5779 0.6283"/>
                <geom class="visual" rgba="0.44 0.5 0.56 1" mesh="mirobot_Link5"/>
                <geom class="collision" rgba="0.44 0.5 0.56 1" mesh="mirobot_Link5"/>

                <body name="Link6" pos="0 -0.01628 0.010525" quat="0.707105 -0.707108 0 0">
                  <inertial pos="0 0 -0.010506" mass="0.01" diaginertia="0.001 0.001 0.001"/>
                  <joint name="joint6" axis="0 0 1" range="-6.2832 6.2832"/>
                  <geom class="visual" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link6"/>
                  <geom class="collision" rgba="0.83 0.83 0.83 1" mesh="mirobot_Link6"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="base_link" body2="Link1"/>
  </contact>

  <actuator>
    <position name="joint1" joint="joint1" class="mirobot" kp="140" kv="14"/>
    <position name="joint2" joint="joint2" class="mirobot" kp="140" kv="14"/>
    <position name="joint3" joint="joint3" class="mirobot" kp="120" kv="12"/>
    <position name="joint4" joint="joint4" class="mirobot" kp="90" kv="10"/>
    <position name="joint5" joint="joint5" class="mirobot" kp="70" kv="8"/>
    <position name="joint6" joint="joint6" class="mirobot" kp="50" kv="6"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0 0 0 0 0" ctrl="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
