<mujoco model="tracer2">
  <compiler meshdir="assets" angle="radian" autolimits="true"/>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" material="gray"/>
    </default>
    <default class="collision">
      <geom group="1" friction="3.0 0.005 0.0001"/>
      <default class="wheel">
        <geom
          type="cylinder"
          size="0.085 0.02"
          condim="4"
          friction="4.0 0.02 0.0001"
        />
      </default>
      <default class="caster">
        <geom
          type="sphere"
          size="0.02"
          friction="0.003 0.0005 0.00005"
          solimp="0.75 0.92 0.001"
          solref="0.03 1"
        />
      </default>
    </default>
  </default>

  <asset>
    <material name="gray" rgba="0.7 0.7 0.7 1"/>
    <material name="dark" rgba="0.2 0.2 0.2 1"/>
    
    <mesh name="base_link" file="base_link.STL"/>
    <mesh name="right_link" file="right_link.STL"/>
    <mesh name="left_Link" file="left_Link.STL"/>
    <mesh name="right_front_link" file="right_front_link.STL"/>
    <mesh name="right_rear_link" file="right_rear_link.STL"/>
    <mesh name="left_front_link" file="left_front_link.STL"/>
    <mesh name="left_rear_link" file="left_rear_link.STL"/>
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0.2">
      <freejoint/>
      <inertial pos="-0.018 0 -0.04" mass="24" diaginertia="0.8 0.6 0.9"/>
      <geom mesh="base_link" class="visual" material="dark"/>
      <geom name="chassis_collision" type="box" pos="-0.01 0 -0.04" size="0.22 0.20 0.04" group="1" rgba="0 0 0 0"/>
      <geom mesh="base_link" type="mesh" group="1" contype="0" conaffinity="0"/>

      <!-- Drive Wheels (The primary contact points) -->
      <body name="right_link" pos="-0.018818 -0.2537 -0.0905" quat="0.7071068 -0.7071068 0 0">
        <joint name="right_joint" axis="0 0 1" damping="0.2" armature="0.02"/>
        <geom mesh="right_link" class="visual"/>
        <geom class="wheel" rgba="1 0 0 0"/> 
      </body>
      <body name="left_link" pos="-0.018818 0.2537 -0.0905" quat="0.7071068 0.7071068 0 0">
        <joint name="left_joint" axis="0 0 1" damping="0.2" armature="0.02"/>
        <geom mesh="left_Link" class="visual"/>
        <geom class="wheel" rgba="1 0 0 0"/>
      </body>

      <!-- Casters: same nominal contact plane as drive wheels, but vertically compliant -->
      <body name="right_front_link" pos="0.23918 -0.1977 -0.1555">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="right_front_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom mesh="right_front_link" pos="0 0 0.0965" quat="0 1 0 0" class="visual"/>
        <geom class="caster" rgba="0 1 0 0"/>
      </body>
      <body name="right_rear_link" pos="-0.27082 -0.183 -0.1555">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="right_rear_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom mesh="right_rear_link" pos="0 0 0.0965" quat="0 1 0 0" class="visual"/>
        <geom class="caster" rgba="0 1 0 0"/>
      </body>
      <body name="left_front_link" pos="0.23918 0.1977 -0.1555">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="left_front_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom mesh="left_front_link" pos="0 0 0.0965" class="visual"/>
        <geom class="caster" rgba="0 1 0 0"/>
      </body>
      <body name="left_rear_link" pos="-0.27077 0.18305 -0.1555">
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.00002 0.00002 0.00002"/>
        <joint name="left_rear_slide" type="slide" axis="0 0 1" range="0 0.01" stiffness="1500" damping="80"/>
        <geom mesh="left_rear_link" pos="0 0 0.0965" class="visual"/>
        <geom class="caster" rgba="0 1 0 0"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="right_drive" joint="right_joint" kv="55" ctrlrange="-18 18"/>
    <velocity name="left_drive" joint="left_joint" kv="55" ctrlrange="-18 18"/>
  </actuator>
</mujoco>
