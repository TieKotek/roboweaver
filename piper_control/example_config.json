{
  "description": "Pick and Place Demo with Custom Scene",
  "scene": {
    "robot_base": [0, 0, 0],
    "friction": [2.0, 0.005, 0.0001],
    "solimp": [0.95, 0.99, 0.001],
    "solref": [0.004, 1],
    "objects": [
      {
        "name": "table",
        "type": "box",
        "size": [0.2, 0.2, 0.05],
        "pos": [0.4, 0, 0.025],
        "rgba": [0.6, 0.4, 0.2, 1],
        "movable": false
      },
      {
        "name": "target_block",
        "type": "box",
        "size": [0.02, 0.02, 0.02],
        "pos": [0.4, 0, 0.09],
        "rgba": [0, 0.8, 0.2, 1],
        "movable": true,
        "mass": 0.01,
        "friction": [5.0, 0.1, 0.001]
      },
      {
        "name": "bin",
        "type": "box",
        "size": [0.05, 0.05, 0.02],
        "pos": [0.0, 0.4, 0.02],
        "rgba": [0.2, 0.2, 0.8, 1],
        "movable": false
      }
    ]
  },
  "sequence": [
    {
      "action": "open_gripper",
      "description": "Ensure gripper is open at start"
    },
    {
      "action": "move_cartesian",
      "description": "Move to approach position above block",
      "parameters": {
        "pose": [0.4, 0, 0.25],
        "duration": 3.0,
        "orientation_needed": false
      }
    },
    {
      "action": "move_cartesian",
      "description": "Move down to block position",
      "parameters": {
        "pose": [0.4, 0, 0.09], 
        "duration": 2.0,
        "orientation_needed": false
      }
    },
    {
      "action": "close_gripper",
      "description": "Grasp the block"
    },
    {
      "action": "idle",
      "description": "Ensure grasp is solid",
      "parameters": { "duration": 0.5 }
    },
    {
      "action": "move_cartesian",
      "description": "Lift the block up",
      "parameters": {
        "pose": [0.4, 0, 0.25],
        "duration": 2.0,
        "orientation_needed": false
      }
    },
    {
      "action": "move_cartesian",
      "description": "Move towards the bin",
      "parameters": {
        "pose": [0.0, 0.4, 0.25],
        "duration": 3.0,
        "orientation_needed": false
      }
    },
    {
      "action": "move_cartesian",
      "description": "Lower block into bin",
      "parameters": {
        "pose": [0.0, 0.4, 0.15],
        "duration": 2.0,
        "orientation_needed": false
      }
    },
    {
      "action": "open_gripper",
      "description": "Release the block"
    },
    {
      "action": "idle",
      "description": "Wait for block to drop",
      "parameters": { "duration": 0.5 }
    },
    {
      "action": "move_cartesian",
      "description": "Move back up",
      "parameters": {
        "pose": [0.0, 0.4, 0.25],
        "duration": 2.0,
        "orientation_needed": false
      }
    },
    {
      "action": "home",
      "description": "Return to home position",
      "parameters": {
        "duration": 3.0
      }
    }
  ]
}
